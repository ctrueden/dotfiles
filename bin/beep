#!/bin/sh

# Emit an audible alert tone. Works on macOS and Linux.

count=${1:-1}
i=0
while [ "$i" -lt "$count" ]; do
  if command -v afplay > /dev/null 2>&1; then
    for sound in /System/Library/Sounds/*.aiff
    do
      afplay "$sound" &
    done
  elif command -v paplay > /dev/null 2>&1; then
    paplay /usr/share/sounds/freedesktop/stereo/complete.oga 2>/dev/null ||
    printf '\a'
  else
    printf '\a'
  fi
  sleep 1
  i=$((i + 1))
done
