#!/usr/bin/env python3
"""
Show Maven dependency version changes between two commits.

Usage: dep-changes [options] [new-ref [old-ref]]

With no arguments, compares HEAD vs HEAD^.
With one argument, compares <ref> vs <ref>^.
With two arguments, compares <new-ref> vs <old-ref>.
"""

import argparse
import contextlib
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path


def run(*cmd, cwd=None, check=True, capture=True):
    kwargs = dict(cwd=cwd, check=check)
    if capture:
        kwargs.update(capture_output=True, text=True)
    return subprocess.run(cmd, **kwargs)


def git_resolve(ref, cwd):
    try:
        return run('git', 'rev-parse', '--verify', '--quiet', ref, cwd=cwd).stdout.strip()
    except subprocess.CalledProcessError:
        sys.exit(f'Error: cannot resolve git ref: {ref!r}')


def git_root(cwd):
    try:
        return run('git', 'rev-parse', '--show-toplevel', cwd=cwd).stdout.strip()
    except subprocess.CalledProcessError:
        sys.exit('Error: not inside a git repository')


@contextlib.contextmanager
def temp_worktree(commit, repo_root):
    tmpdir = tempfile.mkdtemp(prefix='dep-changes-')
    added = False
    try:
        result = run('git', 'worktree', 'add', '--detach', '--quiet', tmpdir, commit,
                     cwd=repo_root, check=False)
        if result.returncode != 0:
            sys.exit(f'Error: failed to create worktree at {commit[:8]}:\n{result.stderr.strip()}')
        added = True
        yield tmpdir
    finally:
        if added:
            run('git', 'worktree', 'remove', '--force', tmpdir, cwd=repo_root, check=False)
        if os.path.exists(tmpdir):
            shutil.rmtree(tmpdir, ignore_errors=True)


def parse_dep_line(line):
    """Parse an mvn dependency:list [INFO] line into a dep dict, or return None."""
    stripped = line.strip()
    if '[INFO]' not in stripped:
        return None
    _, _, rest = stripped.partition('[INFO]')
    rest = rest.strip()
    # Strip trailing module info, e.g. "-- module ch.qos.logback.classic [auto]"
    rest = rest.split(' --')[0].strip()
    tokens = rest.split(':')
    if len(tokens) == 5:
        g, a, p, v, s = tokens
        c = ''
    elif len(tokens) == 6:
        g, a, p, c, v, s = tokens
    else:
        return None
    # Reject lines that look like Maven messages rather than dep coordinates
    if any(' ' in t or not t for t in (g, a, p, v, s)):
        return None
    return {'g': g, 'a': a, 'p': p, 'c': c, 'v': v.strip(), 's': s.strip()}


def get_deps(commit, repo_root, project_subdir):
    """Return a dict of gac-key -> dep for the given commit."""
    print(f'  Resolving deps at {commit[:8]}...', file=sys.stderr)
    with temp_worktree(commit, repo_root) as wt:
        project_dir = os.path.join(wt, project_subdir)
        result = run('mvn', '-B', 'dependency:list', cwd=project_dir, check=False)
        if result.returncode != 0:
            # Warn but still attempt to parse whatever was emitted
            print(f'Warning: mvn exited {result.returncode} at {commit[:8]}', file=sys.stderr)
        deps = {}
        for line in result.stdout.splitlines():
            dep = parse_dep_line(line)
            if dep is None:
                continue
            key = f"{dep['g']}:{dep['a']}:{dep['c']}"
            if key in deps:
                print(f'Warning: duplicate dep {key} at {commit[:8]}', file=sys.stderr)
                continue
            deps[key] = dep
        return deps


def main():
    parser = argparse.ArgumentParser(
        description='Show Maven dependency version changes between two commits.',
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument('new_ref', nargs='?', default='HEAD',
                        help='Newer commit (default: HEAD)')
    parser.add_argument('old_ref', nargs='?', default=None,
                        help='Older commit (default: <new-ref>^)')
    args = parser.parse_args()

    cwd = str(Path.cwd())
    repo_root = git_root(cwd)
    # Track the subdir within the repo so the worktree lands in the right place
    project_subdir = os.path.relpath(cwd, repo_root)

    new_sha = git_resolve(args.new_ref, cwd)
    old_ref_expr = args.old_ref if args.old_ref is not None else f'{args.new_ref}^'
    old_sha = git_resolve(old_ref_expr, cwd)

    print(f'Comparing {old_sha[:8]}..{new_sha[:8]}', file=sys.stderr)

    old_deps = get_deps(old_sha, repo_root, project_subdir)
    new_deps = get_deps(new_sha, repo_root, project_subdir)

    changed = []
    added = []
    removed = []

    all_keys = sorted(set(old_deps) | set(new_deps),
                      key=lambda k: k.split(':')[1])  # sort by artifactId

    for key in all_keys:
        od = old_deps.get(key)
        nd = new_deps.get(key)
        artifact_id = (od or nd)['a']
        classifier = (od or nd)['c']
        cs = f' [{classifier}]' if classifier else ''

        if od is None:
            added.append((artifact_id, cs, nd['v']))
        elif nd is None:
            removed.append((artifact_id, cs, od['v']))
        elif od['v'] != nd['v']:
            changed.append((artifact_id, cs, od['v'], nd['v']))
            if od['p'] != nd['p']:
                print(f'[WARNING] {artifact_id}: packaging changed: {od["p"]} -> {nd["p"]}',
                      file=sys.stderr)
            if od['s'] != nd['s']:
                print(f'[WARNING] {artifact_id}: scope changed: {od["s"]} -> {nd["s"]}',
                      file=sys.stderr)

    def section(title, items, fmt):
        if not items:
            return
        print(f'\n{title}')
        for item in items:
            print(fmt(item))

    section('Changed components:', changed,
            lambda i: f'* {i[0]}{i[1]}: {i[2]} -> {i[3]}')
    section('New components:', added,
            lambda i: f'* {i[0]}{i[1]}: {i[2]}')
    section('Removed components:', removed,
            lambda i: f'* {i[0]}{i[1]}')

    if changed:
        print('\nTo pin all changed deps to old versions:')
        flags = ' \\\n'.join(f'  -D{a}.version={ov}' for a, cs, ov, nv in changed)
        print(flags)


if __name__ == '__main__':
    main()
