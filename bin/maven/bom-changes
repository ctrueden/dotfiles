#!/usr/bin/env python3
"""
Format pom.xml version-property changes as commit-message bullets.

Usage: bom-changes [diff-file]
       git diff HEAD pom.xml | bom-changes

Reads a unified diff from stdin (or a file) and prints one bullet per changed
version property:

  * component: OLD -> NEW
"""

import re
import sys


def main():
    if len(sys.argv) > 1:
        with open(sys.argv[1]) as f:
            lines = f.readlines()
    else:
        lines = sys.stdin.readlines()

    pat = re.compile(r'<([A-Za-z0-9_.-]+)\.version>([^<]+)</')

    old = {}
    new = {}
    order = []

    for line in lines:
        if line.startswith('---') or line.startswith('+++'):
            continue
        if not line.startswith('-') and not line.startswith('+'):
            continue
        m = pat.search(line)
        if not m:
            continue
        name, ver = m.group(1), m.group(2).strip()
        if ver.startswith('${'):
            continue
        if name not in old and name not in new:
            order.append(name)
        if line.startswith('-'):
            old[name] = ver
        else:
            new[name] = ver

    for name in order:
        if name in old and name in new:
            if old[name] != new[name]:
                print(f'* {name}: {old[name]} -> {new[name]}')
        elif name in new:
            print(f'* {name}: {new[name]}')
        elif name in old:
            print(f'* {name} (removed)')


if __name__ == '__main__':
    main()
