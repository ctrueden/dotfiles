#!/bin/sh

# Installs the packages I like.
#
# Usage: install-packages [--gui] [--heavy] [--system]
#   --gui     Include GUI-only packages (require a graphical environment)
#   --heavy   Include large/slow-to-install packages
#   --system  Include host-system packages (hardware, kernel modules, system daemons)

# -- Parse flags --

opt_gui=
opt_heavy=
opt_system=

for arg in "$@"; do
  case "$arg" in
    --gui) opt_gui=1 ;;
    --heavy) opt_heavy=1 ;;
    --system) opt_system=1 ;;
    *) echo "Unknown option: $arg" >&2; exit 1 ;;
  esac
done

# -- Detect package manager --

if command -v apt-get >/dev/null; then
  PM=apt
elif command -v brew >/dev/null; then
  PM=brew
else
  echo "No supported package manager (apt-get or brew) found." >&2
  exit 1
fi

# -- Core packages (always installed) --

# shell
packages="
ansiweather
aspell
bash
bat
boxes
fzf
htop
pwgen
ripgrep
toilet
tree
"

# dev
packages="$packages
cmake
gcc
gh
git-lfs
gnupg
neovim
vim
"

# media
packages="$packages
imagemagick
"

# system
packages="$packages
ca-certificates
coreutils
fontconfig
gettext
graphviz
libtool
m4
netpbm
p11-kit
pkgconf
shared-mime-info
webp
zstd
"

# -- Heavy packages (--heavy) --

# dev
packages_heavy="
pandoc
"

# media
packages_heavy="$packages_heavy
ffmpeg
"

# system
packages_heavy="$packages_heavy
ruby
"

# -- System/host packages (--system) --

packages_system="
wireguard-tools
"

# -- GUI packages (--gui) --

packages_gui=

# -- Platform-specific packages --

if [ "$PM" = apt ]; then

  # shell
  packages="$packages
curl
exuberant-ctags
openssh-client
tldr
zsh
"

  # dev
  packages="$packages
build-essential
myrepos
python-is-python3
"

  # media
  packages="$packages
libtiff-tools
"

  # system/host: hardware + network filesystems
  packages_system="$packages_system
lm-sensors
nfs-common
"

  # gui
  packages_gui="$packages_gui
barrier
dconf-editor
diodon
flatpak
gnome-shell-extension-manager
gnome-system-monitor
gnome-tweaks
guake
kid3-qt
libreoffice
picard
"

elif [ "$PM" = brew ]; then

  # shell
  packages="$packages
tlrc
"

  # dev
  packages="$packages
mr
"

  # media
  packages="$packages
libtiff
"

  # other
  packages="$packages
duti
"

fi

# -- Assemble and install --

all_packages="$packages"
test "$opt_heavy"  && all_packages="$all_packages $packages_heavy"
test "$opt_system" && all_packages="$all_packages $packages_system"
test "$opt_gui"    && all_packages="$all_packages $packages_gui"

if [ "$PM" = apt ]; then

  # gh - adapted from: https://github.com/cli/cli/blob/trunk/docs/install_linux.md
  # Known-good fingerprints: https://github.com/cli/cli/blob/trunk/docs/install_linux.md
  gh_fp1=2C6106201985B60E6C7AC87323F3D4EA75716059
  gh_fp2=7F38BBB59D064DBCB3D84D725612B36462313325
  (type -p curl >/dev/null || (sudo apt update && sudo apt install curl -y)) \
	&& sudo mkdir -p -m 755 /etc/apt/keyrings \
	&& out=$(mktemp) && curl -fsSL -o $out https://cli.github.com/packages/githubcli-archive-keyring.gpg \
	&& gpg --show-keys $out | grep -q "$gh_fp1" \
	&& gpg --show-keys $out | grep -q "$gh_fp2" \
	&& cat $out | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null \
	&& sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
	&& sudo mkdir -p -m 755 /etc/apt/sources.list.d \
	&& echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
	&& sudo apt update \
	&& sudo apt install gh -y

  sudo apt-get update &&
  sudo apt-get install -y $all_packages

elif [ "$PM" = brew ]; then

  brew install $all_packages

fi
