#!/bin/sh

# Installs the packages I like.

# -- Detect package manager --

if command -v apt-get >/dev/null; then
  PM=apt
elif command -v brew >/dev/null; then
  PM=brew
else
  echo "No supported package manager (apt-get or brew) found." >&2
  exit 1
fi

# -- Packages with the same name on both apt and brew --

packages_shell="
ansiweather
aspell
bash
bat
boxes
fzf
htop
pwgen
ripgrep
tldr
toilet
tree
"

packages_dev="
cmake
gcc
gh
git-lfs
gnupg
maven
neovim
pandoc
"

packages_media="
ffmpeg
imagemagick
"

packages_apps="
1password
discord
firefox
ghostty
gimp
libreoffice
vlc
zoom
"

packages_system="
ca-certificates
coreutils
fontconfig
gettext
graphviz
libtool
m4
netpbm
p11-kit
pkgconf
ruby
shared-mime-info
webp
wireguard-tools
zstd
"

# -- Platform-specific packages --

if [ "$PM" = apt ]; then

  packages_shell="$packages_shell
curl
exuberant-ctags
lastpass-cli
lm-sensors
nfs-common
zsh
"

  packages_dev="$packages_dev
ant
build-essential
myrepos
openjdk-8-jdk
openjdk-8-source
openjdk-11-jdk
openjdk-11-source
openjdk-17-jdk
openjdk-17-source
openjdk-21-jdk
openjdk-21-source
openjdk-25-jdk
openjdk-25-source
"

  packages_gnome="
dconf-editor
diodon
gnome-shell-extension-manager
gnome-system-monitor
gnome-tweaks
"

  packages_media="$packages_media
kid3-qt
libtiff-tools
picard
"

  packages_apps="$packages_apps
barrier
guake
meshlab
"

  packages_other="flatpak"

elif [ "$PM" = brew ]; then

  packages_dev="$packages_dev
mr
"

  packages_media="$packages_media
libtiff
"

  packages_other="duti"

  packages_java="
zulu@8
zulu@11
zulu@17
zulu@21
"

fi

all_packages="
$packages_shell
$packages_dev
$packages_media
$packages_apps
$packages_system
${packages_gnome:-}
${packages_other:-}
"

# -- Install --

if [ "$PM" = apt ]; then

  # gh - adapted from: https://github.com/cli/cli/blob/trunk/docs/install_linux.md
  gh_keyring=/usr/share/keyrings/githubcli-archive-keyring.gpg
  if [ ! -e "$gh_keyring" ]
  then
    command -v curl >/dev/null || sudo apt-get install -y curl
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | sudo dd of="$gh_keyring" &&
    sudo chmod go+r "$gh_keyring"
  fi
  gh_apt_list=/etc/apt/sources.list.d/github-cli.list
  if [ ! -e "$gh_apt_list" ]
  then
    echo "deb [arch=$(dpkg --print-architecture) signed-by=$gh_keyring] https://cli.github.com/packages stable main" | sudo tee $gh_apt_list > /dev/null
  fi

  sudo apt-get update &&
  sudo apt-get install $all_packages

elif [ "$PM" = brew ]; then

  brew install $all_packages $packages_java

fi
